# ignore all .txt files
# *.txt
cmake-build-*/
# slash at the end makes it a folder
.idea/
/git-filter-repo.py
.cache/
build/
.DS_Store
.claude/
CLAUDE.md

# Python bytecode (mbedtls build scripts generate these)
__pycache__/
*.pyc

# Relay cert/key. cert.pem is public but regenerated per rotation (no need
# to track). key.pem is the private key and MUST NEVER be committed.
relay/cert.pem
relay/key.pem

